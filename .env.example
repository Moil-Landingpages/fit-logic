NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

GEMINI_API_KEY=""
RESEND_API_KEY=""
SECRET_KEY=""
CRON_SECRET=""
FROM_EMAIL="partners@moilapp.com"

# App URL for email tracking links (set to your production domain in prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Symmetric key used to encrypt OAuth refresh tokens at rest (AES-256-GCM).
# Falls back to SECRET_KEY if unset; set explicitly in production.
TOKEN_ENCRYPTION_KEY=""

# Google OAuth (Gmail + Calendar)
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id-here"

# Microsoft Entra ID OAuth (Outlook Mail + Calendar via Microsoft Graph)
# Use TENANT_ID="common" to support both personal and Microsoft 365 accounts.
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/settings"
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=""
NEXT_PUBLIC_MICROSOFT_TENANT_ID="common"
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI="http://localhost:3000/settings"
